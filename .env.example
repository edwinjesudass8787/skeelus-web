# Environment Variables for Skeelus Web

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Vercel URL (for redirects)
NEXT_PUBLIC_SITE_URL=https://skeelus.vercel.app

# Stripe (for payments)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_SECRET_KEY=sk_test_xxx

# OpenRouter (server-side proxy)
OPENROUTER_API_KEY=sk-or-xxx

# Optional fallback if your hosting provider only exposes this variant
NEXT_PUBLIC_OPENROUTER_API_KEY=sk-or-xxx
